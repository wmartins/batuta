{
  "name": "@batuta/server",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "astryx": "astryx",
    "api-key:create": "tsx scripts/create-api-key.ts",
    "api-key:list": "tsx scripts/list-api-keys.ts",
    "api-key:revoke": "tsx scripts/revoke-api-key.ts",
    "build": "react-router build",
    "check": "biome check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "dev": "react-router dev",
    "openapi:lint": "redocly lint openapi/openapi.yaml",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:blackbox": "react-router build && corepack pnpm --filter @batuta/remote run build && tsx scripts/test-runtime-api.ts",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.3",
    "@astryxdesign/theme-neutral": "0.1.3",
    "@react-router/node": "8.1.0",
    "@react-router/serve": "8.1.0",
    "@stylexjs/stylex": "^0.18.3",
    "batuta": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "isbot": "^5.1.36",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.3",
    "@react-router/dev": "8.1.0",
    "@react-router/fs-routes": "8.1.0",
    "@redocly/cli": "^2.37.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@batuta/remote": "workspace:*",
    "drizzle-kit": "0.31.10",
    "gpt-tokenizer": "^2.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.9"
  }
}
