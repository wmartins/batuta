{
  "name": "@batuta/remote",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "description": "Remote managed-storage adapter and HTTP client for Batuta.",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check .",
    "format": "biome format --write .",
    "openapi:generate": "openapi-typescript ../../apps/server/openapi/openapi.yaml -o src/generated/api.ts",
    "openapi:check": "openapi-typescript ../../apps/server/openapi/openapi.yaml -o src/generated/api.ts --check",
    "test": "vitest run",
    "test:imports": "node test/integration/import-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:imports": "tsc --noEmit -p tsconfig.smoke.json"
  },
  "peerDependencies": {
    "batuta": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "batuta": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
