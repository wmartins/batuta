{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/.react-router",
      "!!**/build",
      "!!**/dist",
      "!!**/node_modules",
      "!!pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": { "preset": "recommended" }
  }
}
